# Copy to .env.deploy on the production host and replace every change-me value.
# This file is safe to commit. The real .env.deploy is ignored by Git.
SERVER_IP=203.0.113.10
PUBLIC_DOMAIN=prox.example.com
NEWAPI_IMAGE=prox-new-api:bootstrap
NODE_NAME=prox-prod-main

PG_PASS=change-me-with-a-long-random-value
REDIS_PASS=change-me-with-a-long-random-value
SESSION_SECRET=change-me-with-at-least-32-random-bytes
CRYPTO_SECRET=change-me-with-at-least-32-random-bytes
SESSION_COOKIE_NAME=prox_session
SESSION_COOKIE_DOMAIN=.example.com
OAUTH_STATE_SIGNING_SECRET=change-me-with-at-least-32-random-bytes

HERMES_SHARED_KEY=change-me-with-at-least-32-random-bytes
HERMES_ADAPTER_URL=http://host.docker.internal:18181
CHATOPS_WEBHOOK_SECRET=change-me-with-at-least-32-random-bytes

COMMUNITY_SITE_ID=prox
COMMUNITY_REWARD_PROVIDER_SLUG=community.example.com
COMMUNITY_REWARD_MISSKEY_HOST=https://community.example.com
COMMUNITY_REWARD_ROOM_ID=
COMMUNITY_REWARD_QUOTA=2500000
COMMUNITY_REWARD_DAILY_QUOTA=500000
COMMUNITY_JOIN_REWARD_ENABLED=false

GLOBAL_WEB_RATE_LIMIT_ENABLE=true
GLOBAL_WEB_RATE_LIMIT=1200
GLOBAL_WEB_RATE_LIMIT_DURATION=60
GLOBAL_API_RATE_LIMIT_ENABLE=true
GLOBAL_API_RATE_LIMIT=1800
GLOBAL_API_RATE_LIMIT_DURATION=60
SEARCH_RATE_LIMIT_ENABLE=true
SEARCH_RATE_LIMIT=120
SEARCH_RATE_LIMIT_DURATION=60
CRITICAL_RATE_LIMIT_ENABLE=true
CRITICAL_RATE_LIMIT=60
CRITICAL_RATE_LIMIT_DURATION=300

STREAMING_TIMEOUT=900
RELAY_IDLE_CONN_TIMEOUT=300
MIAUTH_PERMISSION=read:account
