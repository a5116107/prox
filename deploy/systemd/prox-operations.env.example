# Canonical source and runtime layout. Override these paths during a staged
# migration while the active Compose project still lives elsewhere.
ENV_FILE=/opt/prox/current/.env.deploy
COMPOSE_FILE=/opt/prox/current/compose.prod.yml
RELEASES_DIR=/opt/prox/current/releases
HERMES_ADAPTER_ENV_FILE=/etc/prox/hermes.env
HERMES_STATE_DIR=/var/lib/prox-hermes
IMAGE_REPOSITORY=prox-new-api
MONITOR_CONTAINERS="new-api new-api-proxy new-api-pg new-api-redis new-api-oauth-worker"
