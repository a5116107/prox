OPENAI_BASE_URL=http://127.0.0.1:3000/v1
OPENAI_API_KEY=
HERMES_MODEL=
HERMES_INFERENCE_MODEL=

IMAGE_API_BASE_URL=https://api.acica.top/v1
IMAGE_API_KEY=
