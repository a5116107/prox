SITE_ID=prox
SITE_NAME=prox
BOT_PLATFORM=qq
# Local default. In production, set this to the prox-prod Compose bridge gateway.
HERMES_ADAPTER_HOST=127.0.0.1
HERMES_ADAPTER_PORT=18181
# Optional exact health endpoint override used by deployment and operations scripts.
# HERMES_ADAPTER_HEALTH_URL=http://172.19.0.1:18181/health
HERMES_ADAPTER_SYSTEMD_UNIT=prox-hermes-adapter.service

HERMES_ADAPTER_KEY=change-me-with-at-least-32-random-bytes
GAME_ADMIN_KEY=change-me-with-at-least-32-random-bytes
# Local defaults. Candidate-only production containers do not publish port 3000;
# set both URLs to the host Nginx endpoint, for example http://SERVER_IP.
CHATOPS_WEBHOOK_SECRET=change-me-with-at-least-32-random-bytes
NEWAPI_INTERNAL_BASE_URL=http://127.0.0.1:3000
NEWAPI_CHATOPS_BASE_URL=http://127.0.0.1:3000

OPENAI_BASE_URL=http://127.0.0.1:3000/v1
OPENAI_API_KEY=
HERMES_MODEL=
HERMES_INFERENCE_MODEL=

# Refresh image settings from New API. Environment values below remain the
# startup and outage fallback; a non-empty admin API key takes precedence.
IMAGE_CONFIG_FROM_NEWAPI=true
IMAGE_CONFIG_CACHE_TTL_SECONDS=15
IMAGE_CONFIG_FETCH_TIMEOUT_SECONDS=2
IMAGE_API_BASE_URL=https://api.acica.top/v1
IMAGE_API_KEY=
IMAGE_MODEL=gpt-image-2
IMAGE_SIZE=1024x1024
IMAGE_TIMEOUT=180
IMAGE_RETRY_LIMIT=2
IMAGE_RETRY_BASE_DELAY=3
IMAGE_RETRY_MAX_DELAY=15
IMAGE_COOLDOWN_SECONDS=45
IMAGE_REQUIRE_BIND=0

ONEBOT_URL=http://127.0.0.1:13000
ONEBOT_TOKEN=
ONEBOT_WEBHOOK_SECRET=
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

HERMES_STATE_DIR=/var/lib/prox-hermes
HERMES_GAME_CONFIG_CACHE=/var/lib/prox-hermes/game_config.json
HERMES_LEARNING_STORE=/var/lib/prox-hermes/learning_store.json
HERMES_LEADERBOARD_STORE=/var/lib/prox-hermes/leaderboard_stats.json
HERMES_GAME_CONFIG_TTL_SECONDS=30
HERMES_GAME_ALLOW_PLUGIN_DEFAULTS=false

REFLECTION_INTERVAL_SECONDS=21600
REFLECTION_MODEL=
# REFLECTION_API_BASE and REFLECTION_API_KEY are optional and must be injected at runtime.
